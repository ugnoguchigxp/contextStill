{
  "$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "a11y": {
        "noLabelWithoutControl": {
          "level": "error",
          "options": {
            "inputComponents": ["Input", "Select", "Checkbox"]
          }
        }
      },
      "suspicious": {
        "noExplicitAny": "off",
        "noThenProperty": "off"
      }
    }
  },
  "organizeImports": {
    "enabled": true
  },
  "files": {
    "ignore": [
      "coverage/**",
      "coverage.json",
      "dist/**",
      "dist-web/**",
      "drizzle/meta/**",
      "playwright-report/**",
      "test-results/**",
      "src/db/seeds/knowledge-seed.json"
    ]
  }
}
