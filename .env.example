DATABASE_URL=postgres://postgres:postgres@localhost:7889/memory_router
MEMORY_ROUTER_EMBEDDING_DIMENSION=384
MEMORY_ROUTER_EMBEDDING_PROVIDER=auto
MEMORY_ROUTER_EMBEDDING_DAEMON_URL=http://127.0.0.1:44512
MEMORY_ROUTER_EMBEDDING_TIMEOUT_MS=10000
