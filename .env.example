DATABASE_URL=postgres://postgres:postgres@localhost:7889/memory_router
MEMORY_ROUTER_EMBEDDING_DIMENSION=384
MEMORY_ROUTER_EMBEDDING_PROVIDER=auto
MEMORY_ROUTER_EMBEDDING_DAEMON_URL=http://127.0.0.1:44512
MEMORY_ROUTER_EMBEDDING_TIMEOUT_MS=10000
# Optional. Defaults assume sibling repo: ../local-llm/embedding
# MEMORY_ROUTER_LOCAL_LLM_EMBEDDING_ROOT=/Users/y.noguchi/Code/local-llm/embedding
# MEMORY_ROUTER_LOCAL_LLM_EMBEDDING_PYTHON=/Users/y.noguchi/Code/local-llm/embedding/.venv/bin/python
# MEMORY_ROUTER_LOCAL_LLM_EMBEDDING_MODEL_DIR=/Users/y.noguchi/Code/local-llm/embedding/models/multilingual-e5-small
# Optional. Default: this repo's local wiki root: ./wiki
# MEMORY_ROUTER_SOURCE_CONTENT_ROOT=/Users/y.noguchi/Code/memoryRouter/wiki
# Agent log sync. Defaults follow this machine's Codex and Antigravity locations.
# MEMORY_ROUTER_CODEX_SESSION_DIR=/Users/y.noguchi/.codex/sessions
# MEMORY_ROUTER_CODEX_ARCHIVED_SESSION_DIR=/Users/y.noguchi/.codex/archived_sessions
# MEMORY_ROUTER_ANTIGRAVITY_LOG_DIR=/Users/y.noguchi/.gemini/antigravity/brain
MEMORY_ROUTER_AGENT_LOG_SYNC_INTERVAL_SECONDS=3600
MEMORY_ROUTER_AGENT_LOG_INITIAL_LOOKBACK_HOURS=168
MEMORY_ROUTER_AGENT_LOG_MAX_MESSAGES_PER_CHUNK=120
MEMORY_ROUTER_AGENT_LOG_MAX_CHARS_PER_CHUNK=12000
MEMORY_ROUTER_AGENT_LOG_SYNC_LOCK_TTL_SECONDS=1800
MEMORY_ROUTER_DEFAULT_TOKEN_BUDGET=3000
MEMORY_ROUTER_ENABLE_VECTOR_SEARCH=true
MEMORY_ROUTER_DOCTOR_FRESHNESS_THRESHOLD_MINUTES=720
MEMORY_ROUTER_DOCTOR_DEGRADED_RATE_THRESHOLD=0.5
