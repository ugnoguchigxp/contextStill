DATABASE_URL=postgres://postgres:postgres@localhost:7889/memory_router

# Agentic Compile LLM Provider
MEMORY_ROUTER_CONTEXT_COMPILE_AGENTIC_PROVIDER=azure-openai
MEMORY_ROUTER_CONTEXT_COMPILE_AGENTIC_ENABLED=true
MEMORY_ROUTER_CONTEXT_COMPILE_AGENTIC_TIMEOUT_MS=10000
MEMORY_ROUTER_CONTEXT_COMPILE_AGENTIC_MAX_TOKENS=2048

# Distillation LLM Provider
MEMORY_ROUTER_DISTILLATION_PROVIDER=local-llm
MEMORY_ROUTER_DISTILLATION_TIMEOUT_MS=300000
MEMORY_ROUTER_DISTILLATION_LOCK_TTL_SECONDS=7200
# MEMORY_ROUTER_DISTILLATION_LOCK_FILE=/path/to/distillation.lock

# Azure OpenAI (Agentic Compile / Distillation)
MEMORY_ROUTER_AZURE_OPENAI_API_KEY=
MEMORY_ROUTER_AZURE_OPENAI_API_BASE_URL=https://your-resource.openai.azure.com
MEMORY_ROUTER_AZURE_OPENAI_API_VERSION=2025-04-01-preview
MEMORY_ROUTER_AZURE_OPENAI_MODEL=gpt-5-4-mini

# AWS Bedrock (Agentic Compile / Distillation)
MEMORY_ROUTER_BEDROCK_MODEL=
MEMORY_ROUTER_BEDROCK_REGION=us-east-1
MEMORY_ROUTER_BEDROCK_PROFILE=

# External Search
BRAVE_SEARCH_API_KEY=

# Local LLM
MEMORY_ROUTER_LOCAL_LLM_API_BASE_URL=http://127.0.0.1:44448
MEMORY_ROUTER_LOCAL_LLM_MODEL=gemma-4-e4b-it
MEMORY_ROUTER_LOCAL_LLM_API_KEY=

# Log Paths
MEMORY_ROUTER_ANTIGRAVITY_LOG_DIR=/Users/y.noguchi/.gemini/antigravity/brain
