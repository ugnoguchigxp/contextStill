DATABASE_URL=postgres://postgres:postgres@localhost:7889/context_still
CONTEXT_STILL_LANG=ja
# MCP v2 tool surface (default on). Set to 0/false to expose legacy v1 surface.
# CONTEXT_STILL_MCP_V2=1

# Distillation search provider order (kept intentionally)
CONTEXT_STILL_DISTILLATION_SEARCH_PROVIDERS=brave,exa
# Distillation LLM provider: local-llm | azure-openai | bedrock | auto
CONTEXT_STILL_DISTILLATION_PROVIDER=local-llm
# Optional findCandidate-only override. Unset inherits CONTEXT_STILL_DISTILLATION_PROVIDER.
# CONTEXT_STILL_DISTILLATION_FIND_CANDIDATE_PROVIDER=azure-openai
# Keep findCandidate lane always active without schedule waits (default: 1).
# Set 0 to restore interactive-pressure/cooldown based waiting.
# CONTEXT_STILL_FIND_CANDIDATE_NO_WAIT=1

# Azure OpenAI (Agentic Compile / Distillation)
CONTEXT_STILL_AZURE_OPENAI_API_KEY=
CONTEXT_STILL_AZURE_OPENAI_API_BASE_URL=https://your-resource.openai.azure.com

# AWS Bedrock (Agentic Compile / Distillation)
CONTEXT_STILL_BEDROCK_REGION=us-east-1
CONTEXT_STILL_BEDROCK_PROFILE=

# External Search
BRAVE_SEARCH_API_KEY=
CONTEXT_STILL_EXA_API_KEY=
EXA_API_KEY=

# Local LLM endpoint/secret
CONTEXT_STILL_LOCAL_LLM_API_BASE_URL=http://127.0.0.1:44448
CONTEXT_STILL_LOCAL_LLM_API_KEY=

# Embedding daemon endpoint/secret
CONTEXT_STILL_EMBEDDING_DAEMON_URL=http://127.0.0.1:44512
CONTEXT_STILL_EMBEDDING_ACCESS_TOKEN=

# Optional machine-local path overrides
# CONTEXT_STILL_CODEX_SESSION_DIR=/Users/your-user/.codex/sessions
# CONTEXT_STILL_CODEX_ARCHIVED_SESSION_DIR=/Users/your-user/.codex/archived_sessions
# CONTEXT_STILL_ANTIGRAVITY_LOG_DIR=/Users/your-user/.gemini/antigravity/brain
# CONTEXT_STILL_CODEX_SESSION_DIRS=/path/to/sessions1,/path/to/sessions2
# CONTEXT_STILL_CODEX_ARCHIVED_SESSION_DIRS=/path/to/archived1,/path/to/archived2
# CONTEXT_STILL_ANTIGRAVITY_LOG_DIRS=/path/to/brain1,/path/to/brain2

# Distillation conveyor LaunchAgent options
# CONTEXT_STILL_DISTILL_PIPELINE_INTERVAL_SECONDS=120
# CONTEXT_STILL_DISTILL_PIPELINE_KIND=auto
# CONTEXT_STILL_DISTILL_PIPELINE_LIMIT=1
# CONTEXT_STILL_DISTILL_PIPELINE_REFRESH=1
# CONTEXT_STILL_DISTILL_PIPELINE_PROVIDER=
# Set 0 to force single-provider mode when CONTEXT_STILL_DISTILL_PIPELINE_PROVIDER is set.
# Default (unset/1) keeps route fallback enabled.
# CONTEXT_STILL_DISTILL_PIPELINE_PROVIDER_FALLBACK=1
# CONTEXT_STILL_DISTILL_PIPELINE_VERSION=select-distillation-target-v1
