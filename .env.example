DATABASE_URL=postgres://postgres:postgres@localhost:7889/memory_router

# Distillation search provider order (kept intentionally)
MEMORY_ROUTER_DISTILLATION_SEARCH_PROVIDERS=brave,exa
# Distillation LLM provider: local-llm | azure-openai | bedrock | auto
MEMORY_ROUTER_DISTILLATION_PROVIDER=local-llm

# Azure OpenAI (Agentic Compile / Distillation)
MEMORY_ROUTER_AZURE_OPENAI_API_KEY=
MEMORY_ROUTER_AZURE_OPENAI_API_BASE_URL=https://your-resource.openai.azure.com

# AWS Bedrock (Agentic Compile / Distillation)
MEMORY_ROUTER_BEDROCK_REGION=us-east-1
MEMORY_ROUTER_BEDROCK_PROFILE=

# External Search
BRAVE_SEARCH_API_KEY=
MEMORY_ROUTER_EXA_API_KEY=
EXA_API_KEY=

# Local LLM endpoint/secret
MEMORY_ROUTER_LOCAL_LLM_API_BASE_URL=http://127.0.0.1:44448
MEMORY_ROUTER_LOCAL_LLM_API_KEY=

# Embedding daemon endpoint/secret
MEMORY_ROUTER_EMBEDDING_DAEMON_URL=http://127.0.0.1:44512
MEMORY_ROUTER_EMBEDDING_ACCESS_TOKEN=

# Optional machine-local path overrides
# MEMORY_ROUTER_CODEX_SESSION_DIR=/Users/your-user/.codex/sessions
# MEMORY_ROUTER_CODEX_ARCHIVED_SESSION_DIR=/Users/your-user/.codex/archived_sessions
# MEMORY_ROUTER_ANTIGRAVITY_LOG_DIR=/Users/your-user/.gemini/antigravity/brain

# Distillation conveyor LaunchAgent options
# MEMORY_ROUTER_DISTILL_PIPELINE_INTERVAL_SECONDS=120
# MEMORY_ROUTER_DISTILL_PIPELINE_KIND=auto
# MEMORY_ROUTER_DISTILL_PIPELINE_LIMIT=1
# MEMORY_ROUTER_DISTILL_PIPELINE_REFRESH=1
# MEMORY_ROUTER_DISTILL_PIPELINE_PROVIDER=
# MEMORY_ROUTER_DISTILL_PIPELINE_VERSION=select-distillation-target-v1
