{
  "name": "memory-router",
  "version": "0.1.0",
  "description": "Local-first context compiler for coding agents",
  "license": "MIT",
  "type": "module",
  "packageManager": "bun@1.3.12",
  "scripts": {
    "start": "bun run src/index.ts",
    "compile": "bun run src/cli/compile.ts",
    "import:markdown": "bun run src/cli/import-markdown.ts",
    "doctor": "bun run src/cli/doctor.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:seed": "bun run src/db/seed.ts",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "format": "biome format --write .",
    "test": "bun run test:unit",
    "test:unit": "bun test test/repositories.test.ts test/markdown-importer.test.ts test/context-compiler.test.ts",
    "test:integration": "MEMORY_ROUTER_RUN_DB_TESTS=1 bun test test/*.integration.test.ts test/*.e2e.test.ts test/mcp.contract.test.ts",
    "test:all": "bun run test:unit && bun run test:integration",
    "verify": "bun run typecheck && bun run lint && bun run test"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.45.2",
    "pg": "^8.16.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/pg": "^8.20.0",
    "bun-types": "1.3.12",
    "drizzle-kit": "^0.31.10",
    "typescript": "^6.0.2"
  }
}
