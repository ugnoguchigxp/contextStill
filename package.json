{
  "name": "context-still",
  "version": "0.1.0",
  "description": "Local-first context compiler for coding agents",
  "license": "MIT",
  "type": "module",
  "bin": {
    "context-still": "./src/cli/context-still.ts",
    "memory-router": "./src/cli/context-still.ts"
  },
  "packageManager": "bun@1.3.14",
  "scripts": {
    "dev": "bun ./node_modules/vite/bin/vite.js",
    "start": "bun run start:mcp",
    "start:mcp": "bun run src/index.ts",
    "start:api": "bun run api/index.ts",
    "build:web": "vite build",
    "preview:web": "vite preview",
    "lp:optimize-image": "bun run github-pages/scripts/optimize-hero-image.ts",
    "lp:lighthouse": "bash github-pages/scripts/run-lighthouse.sh",
    "compile": "bun run src/cli/compile.ts",
    "init:project": "bun run src/cli/init-project.ts",
    "setup": "bun run src/cli/setup.ts",
    "setup:mcp-config": "bun run src/cli/setup-mcp-config.ts",
    "startup": "bun run src/cli/startup.ts",
    "setup:interactive": "bun run src/cli/startup.ts",
    "import:markdown": "bun run src/cli/import-markdown.ts",
    "import:wiki": "bun run src/cli/import-sources.ts",
    "import:sources": "bun run src/cli/import-sources.ts",
    "sync:agent-logs": "bun run src/cli/sync-agent-logs.ts",
    "distill:domain": "bun run src/cli/distill-domain.ts",
    "backfill:knowledge-project-context": "bun run src/cli/backfill-knowledge-project-context.ts",
    "backfill:knowledge-value": "bun run src/cli/backfill-knowledge-value.ts",
    "backfill:knowledge-source-links": "bun run src/cli/backfill-knowledge-source-links.ts",
    "backfill:knowledge-origin-links": "bun run src/cli/backfill-knowledge-origin-links.ts",
    "knowledge:apply-feedback-quality": "bun run src/cli/apply-knowledge-quality.ts",
    "landscape": "bun run src/cli/landscape.ts",
    "context-still": "bun run src/cli/context-still.ts",
    "memory-router": "bun run src/cli/context-still.ts",
    "seed:knowledge-tags": "bun run src/cli/seed-knowledge-tags.ts",
    "doctor": "bun run src/cli/doctor.ts",
    "mcp:smoke": "DATABASE_URL=${CONTEXT_STILL_TEST_DATABASE_URL:-postgres://postgres:postgres@localhost:7889/context_still_test} bun run src/cli/mcp-smoke.ts",
    "read-file:smoke": "bun run src/cli/read-file-smoke.ts",
    "memory-reader:smoke": "bun run src/cli/memory-reader-smoke.ts",
    "find-candidate": "bun run src/cli/find-candidate.ts",
    "cover-evidence": "bun run src/cli/cover-evidence.ts",
    "eval:context": "bun run src/cli/eval-context.ts",
    "finalize-distille": "bun run src/cli/finalize-distille.ts",
    "queue:finding:once": "bun run src/cli/queue.ts --queue findingCandidate --once --limit 1",
    "queue:covering:once": "bun run src/cli/queue.ts --queue coveringEvidence --once --limit 1",
    "queue:merge-review:once": "bun run src/cli/queue.ts --queue deadZoneMergeReview --once --limit 1",
    "queue:finalize:once": "bun run src/cli/queue.ts --queue finalizeDistille --once --limit 1",
    "queue:merge-activation-finalize:once": "bun run src/cli/queue.ts --queue mergeActivationFinalize --once --limit 1",
    "queue:supervisor": "bun run src/cli/queue-supervisor.ts --continuous --limit 1",
    "queue:migrate:dry-run": "bun run src/cli/queue-migrate.ts --dry-run",
    "queue:migrate:write": "bun run src/cli/queue-migrate.ts --write --backup",
    "distill:reprocess-rejected": "bun run src/cli/reprocess-rejected-candidates.ts",
    "automation:agent-log-sync": "bun run src/cli/agent-log-sync-automation.ts",
    "automation:queue-supervisor": "bun run src/cli/queue-supervisor-automation.ts",
    "automation:agent-log-sync:windows": "bun run src/cli/agent-log-sync-automation.ts",
    "automation:queue-supervisor:windows": "bun run src/cli/queue-supervisor-automation.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:seed:export": "bash ./scripts/export-knowledge-seed.sh",
    "db:seed": "bun run src/db/seed.ts",
    "seed:llm-usage-sample": "bun run src/cli/seed-llm-usage-sample.ts",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "test": "bun run test:unit",
    "test:ui": "vitest run",
    "test:e2e": "playwright test",
    "test:unit": "bunx vitest run --exclude \"test/*.integration.test.ts\" --exclude \"test/*.e2e.test.ts\"",
    "test:unit:api": "bunx vitest run test/api.routes.test.ts",
    "test:integration": "DATABASE_URL=${CONTEXT_STILL_TEST_DATABASE_URL:-postgres://postgres:postgres@localhost:7889/context_still_test} bun run db:migrate && DATABASE_URL=${CONTEXT_STILL_TEST_DATABASE_URL:-postgres://postgres:postgres@localhost:7889/context_still_test} CONTEXT_STILL_RUN_DB_TESTS=1 bun test --timeout=30000 --max-concurrency=1 test/*.integration.test.ts test/*.e2e.test.ts test/mcp.contract.test.ts",
    "test:all": "bun run test:unit && bun run test:integration",
    "verify": "bun run typecheck && bun run lint && bun run format:check && bun run test:unit && bun run build:web",
    "verify:mcp": "DATABASE_URL=${CONTEXT_STILL_TEST_DATABASE_URL:-postgres://postgres:postgres@localhost:7889/context_still_test} bun run db:migrate && DATABASE_URL=${CONTEXT_STILL_TEST_DATABASE_URL:-postgres://postgres:postgres@localhost:7889/context_still_test} bun run test:mcp:contract && DATABASE_URL=${CONTEXT_STILL_TEST_DATABASE_URL:-postgres://postgres:postgres@localhost:7889/context_still_test} bun run mcp:smoke && DATABASE_URL=${CONTEXT_STILL_TEST_DATABASE_URL:-postgres://postgres:postgres@localhost:7889/context_still_test} bun run doctor",
    "test:mcp:contract": "DATABASE_URL=${CONTEXT_STILL_TEST_DATABASE_URL:-postgres://postgres:postgres@localhost:7889/context_still_test} CONTEXT_STILL_RUN_DB_TESTS=1 bun test --timeout=30000 --max-concurrency=1 test/mcp.contract.test.ts"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.1047.0",
    "@hono/node-server": "2.0.2",
    "@hono/zod-validator": "0.8.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@openai/codex-sdk": "^0.135.0",
    "@radix-ui/react-label": "2.1.8",
    "@tanstack/react-query": "5.100.10",
    "@tanstack/react-router": "1.169.2",
    "@tanstack/react-table": "8.21.3",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.45.2",
    "gray-matter": "^4.0.3",
    "hono": "4.12.18",
    "lucide-react": "^0.552.0",
    "markdown-wysiwyg-editor": "^0.3.8",
    "mermaid": "^11.12.0",
    "node-html-markdown": "^2.0.0",
    "pg": "^8.16.3",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-hook-form": "7.75.0",
    "recharts": "^3.8.1",
    "sanitize-html": "^2.17.0",
    "tailwind-merge": "3.6.0",
    "xlsx": "^0.18.5",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@hono/vite-dev-server": "0.25.3",
    "@playwright/test": "1.60.0",
    "@tailwindcss/vite": "4.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/pg": "^8.20.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/sanitize-html": "^2.16.0",
    "@vitejs/plugin-react": "6.0.1",
    "@vitest/coverage-v8": "^4.1.6",
    "bun-types": "1.3.12",
    "drizzle-kit": "^0.31.10",
    "jsdom": "^29.1.1",
    "tailwindcss": "4.3.0",
    "tw-animate-css": "1.4.0",
    "typescript": "^6.0.2",
    "vite": "8.0.12",
    "vitest": "4.1.6"
  },
  "overrides": {
    "@tanstack/react-router": "1.169.2",
    "@tanstack/router-core": "1.169.2",
    "@tanstack/history": "1.161.6"
  }
}
